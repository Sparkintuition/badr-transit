PORT=3000

# "development" for dev mode (two processes), "production" for prod (single process)
NODE_ENV=production

# Set to true to serve the built React frontend from backend (production mode)
SERVE_FRONTEND=true

# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-minimum-32-chars

# Backup configuration
BACKUP_DIR=C:\path\to\backups
BACKUP_RETENTION_DAYS=30
